# Database
POSTGRES_PASSWORD=payload
# When running locally (without Docker): use localhost on port 5433 (mapped in docker-compose.yml)
DATABASE_URL=postgres://payload:payload@localhost:5434/solidus-website
# When running via Docker Compose: the app service sets DATABASE_URL automatically
# using the "postgres" service name as host (handled in docker-compose.yml)

# Payload
PAYLOAD_SECRET=your-secret-here
NEXT_PUBLIC_SERVER_URL=http://localhost:3002

# Cron & Preview
CRON_SECRET=your-cron-secret-here
PREVIEW_SECRET=your-preview-secret-here

# Scaleway S3 Storage
S3_BUCKET=REPLACE_WITH_BUCKET_NAME
S3_ENDPOINT=https://s3.nl-ams.scw.cloud
S3_REGION=nl-ams
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
