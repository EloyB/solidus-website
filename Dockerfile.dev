FROM oven/bun:1

WORKDIR /app

# Install dependencies only (source code is volume-mounted at runtime)
COPY package.json bun.lock ./
RUN bun install

# Expose Next.js dev server port
EXPOSE 3000

# Run dev server bound to all interfaces so it's accessible from the host
CMD ["bun", "run", "dev", "--hostname", "0.0.0.0"]
